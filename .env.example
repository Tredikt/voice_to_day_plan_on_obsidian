# Telegram Bot Token (obtained from @BotFather)
TELEGRAM_BOT_TOKEN=

# SOCKS5/HTTP proxy for the bot (e.g. socks5://user:pass@host:port or http://host:port)
TELEGRAM_PROXY=

# OpenAI API Key (required for Whisper audio transcription)
OPENAI_API_KEY=

# DeepSeek API Key (if provided, DeepSeek will be used for structuring tasks; otherwise falls back to OpenAI)
DEEPSEEK_API_KEY=

# Allowed Telegram User IDs (comma-separated, e.g. 1234567,9876543)
# Leave empty to allow any Telegram user to use the bot
ALLOWED_TELEGRAM_IDS=1283802964

# Storage Provider: "yandex" or "google"
STORAGE_PROVIDER=yandex

# Yandex WebDAV Configuration (required if STORAGE_PROVIDER=yandex)
YANDEX_USER=
YANDEX_PASSWORD=
YANDEX_OBSIDIAN_DIR=/ObsidianVault/Day-plans

# Google Drive Configuration (required if STORAGE_PROVIDER=google)
# Can be a path to service account JSON (e.g. google-credentials.json) or raw inline JSON string
GOOGLE_CREDENTIALS_JSON=
GOOGLE_OBSIDIAN_DIR_ID=

# Google Calendar Configuration (Optional, leave blank to disable)
# ID of your calendar, e.g. your_email@gmail.com.
# Requires the service account in GOOGLE_CREDENTIALS_JSON to have access to this calendar!
GOOGLE_CALENDAR_ID=
# Timezone of your calendar events (e.g. Europe/Moscow, Asia/Tashkent, etc.)
TIMEZONE=Europe/Moscow

